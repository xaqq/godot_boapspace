[gd_scene format=3]

[node name="RoadsPanel" type="RoadsPanel" node_paths=PackedStringArray("dirt_button", "cobblestone_button", "flagstone_button", "active_label", "stroke_label", "errors_label")]
dirt_button = NodePath("Margin/VBox/DirtButton")
cobblestone_button = NodePath("Margin/VBox/CobblestoneButton")
flagstone_button = NodePath("Margin/VBox/FlagstoneButton")
active_label = NodePath("Margin/VBox/ActiveLabel")
stroke_label = NodePath("Margin/VBox/StrokeLabel")
errors_label = NodePath("Margin/VBox/ErrorsLabel")
custom_minimum_size = Vector2(200, 0)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 8

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Roads"

[node name="Separator" type="HSeparator" parent="Margin/VBox"]
layout_mode = 2

[node name="DirtButton" type="Button" parent="Margin/VBox"]
layout_mode = 2
text = "Dirt Path — Free — 1.5×"

[node name="CobblestoneButton" type="Button" parent="Margin/VBox"]
layout_mode = 2
text = "Cobblestone — 1 Stone — 2×"

[node name="FlagstoneButton" type="Button" parent="Margin/VBox"]
layout_mode = 2
text = "Flagstone — 1 Stone Block — 3×"

[node name="ActiveLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Active road: None"

[node name="HintLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Right-click or Escape to cancel"
autowrap_mode = 2

[node name="StrokeLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Stroke: 0 cell(s) | Cost: None"
autowrap_mode = 2

[node name="ErrorsLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Valid stroke"
autowrap_mode = 2

