[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = false

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/libgodot_boapspace_rust.so"
linux.release.x86_64 =   "res://../rust/target/release/libgodot_boapspace_rust.so"
windows.debug.x86_64 =   "res://../rust/target/debug/godot_boapspace_rust.dll"
windows.release.x86_64 = "res://../rust/target/release/godot_boapspace_rust.dll"
macos.debug =            "res://../rust/target/debug/libgodot_boapspace_rust.dylib"
macos.release =          "res://../rust/target/release/libgodot_boapspace_rust.dylib"
